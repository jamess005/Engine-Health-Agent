# Database — SQLite (file-based, no server required)
# For PostgreSQL: set DB_PASSWORD and update DB_PATH to a connection string.
# SQLite access is controlled by OS-level file permissions on DB_PATH.
DB_PATH=data/engine_health.db
DB_USER=your_username
DB_PASSWORD=change-me-use-a-strong-random-password

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# AMD ROCm GPU override — set to your GFX version, or remove for CUDA/CPU
# HSA_OVERRIDE_GFX_VERSION=11.0.0
