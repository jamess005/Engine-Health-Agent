# Database — SQLite (file-based; no server or credentials required)
# Access is controlled by OS file permissions on DB_PATH.
DB_PATH=data/engine_health.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# AMD ROCm GPU override — set to your GFX version, or remove for CUDA/CPU
# HSA_OVERRIDE_GFX_VERSION=11.0.0
